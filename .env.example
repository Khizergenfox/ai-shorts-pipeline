# ai-shorts-pipeline — environment variables
# Copy this file to `.env` and fill in your own values.
# Never commit your real .env file. (The .gitignore already excludes it.)

# === Required for v0.1 (dashboard) ===
# The dashboard runs without any API keys. PORT is optional.
PORT=5173

# === Required for v0.2+ (render pipeline) — coming soon ===

# ElevenLabs — voice generation
# Sign up at https://elevenlabs.io, then get a key + clone or pick a voice ID.
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# Google Vertex AI — Veo b-roll + Imagen seed images
# Optional. Leave empty to skip Veo b-roll generation in renders.
# Set up: https://console.cloud.google.com → Vertex AI → service account JSON.
GOOGLE_VERTEX_PROJECT=
GOOGLE_VERTEX_LOCATION=us-central1
GOOGLE_APPLICATION_CREDENTIALS=

# Gemini — script analysis + narration drafting
# Free tier works fine: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Anthropic Claude — orchestration (if running outside Claude Code)
# Optional. Only needed if you call the orchestrator from your own Node script
# instead of using Claude Code as the runner.
ANTHROPIC_API_KEY=

# YouTube Data API — for the /publish/youtube uploader (v0.3+)
# Optional until you wire up auto-upload.
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REFRESH_TOKEN=
